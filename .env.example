# ==========================================
# TELEGRAM BOT CONFIGURATION
# ==========================================
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_BOT_NAME=NovaVestBot
TELEGRAM_BOT_USERNAME=novavest_bot
TELEGRAM_APP_URL=https://your-mini-app-domain.com

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# PostgreSQL (Production)
DATABASE_URL=postgresql://user:password@localhost:5432/novavest_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your_db_password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=novavest_db

# SQLite (Development)
DATABASE_DEV=sqlite:./dev.db

# ==========================================
# SERVER CONFIGURATION
# ==========================================
NODE_ENV=development
PORT=3000
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ==========================================
# SECURITY & JWT
# ==========================================
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# ==========================================
# ADMIN CONFIGURATION
# ==========================================
# Comma-separated Telegram user IDs with admin access
ADMIN_IDS=123456789,987654321

# ==========================================
# EMAIL CONFIGURATION (Optional)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@novavest.com
SMTP_FROM_NAME=NovaVest Platform

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOCK_TIME_MS=3600000

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info
LOG_FILE=logs/app.log
ERROR_LOG_FILE=logs/error.log

# ==========================================
# FEATURES & SETTINGS
# ==========================================
MIN_DEPOSIT=1000
MAX_DEPOSIT=1000000
MIN_WITHDRAWAL=500
MAX_WITHDRAWAL=500000
REFERRAL_REWARD=500
DEFAULT_CURRENCY=NGN

# ==========================================
# PAYMENT GATEWAY (Optional)
# ==========================================
PAYMENT_PROVIDER=paystack
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_SECRET_KEY=your_paystack_secret_key

# ==========================================
# EXTERNAL SERVICES (Optional)
# ==========================================
SENTRY_DSN=your_sentry_dsn_for_error_tracking
REDIS_URL=redis://localhost:6379

# ==========================================
# CORS & SECURITY
# ==========================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
TRUST_PROXY=true

# ==========================================
# DEVELOPMENT ONLY
# ==========================================
DEBUG=false
MOCK_PAYMENT=false
