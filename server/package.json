{
  "name": "novavest-server",
  "version": "1.0.0",
  "description": "NovaVest Platform Backend - Telegram Bot & Investment Platform",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "build": "echo 'No build step required for Node.js'",
    "test": "node --test src/**/*.test.js",
    "test:coverage": "node --test --coverage src/**/*.test.js",
    "lint": "eslint src/**/*.js --fix || true",
    "format": "prettier --write src/**/*.js || true",
    "db:init": "node scripts/initDb.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js"
  },
  "keywords": [
    "telegram",
    "bot",
    "investment",
    "platform"
  ],
  "author": "Dooze123",
  "license": "MIT",
  "dependencies": {
    "telegraf": "^4.15.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "joi": "^17.11.0",
    "axios": "^1.6.2",
    "redis": "^4.6.12",
    "crypto-random-string": "^5.0.0",
    "nodemailer": "^6.9.7",
    "uuid": "^9.0.1",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-validator": "^7.0.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
